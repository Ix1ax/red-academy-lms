# ─── База данных ────────────────────────────────────────────────────────────
POSTGRES_DB=lms_platform
POSTGRES_USER=lms
POSTGRES_PASSWORD=lms_password
POSTGRES_PORT=5432

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ─── RabbitMQ ───────────────────────────────────────────────────────────────
RABBITMQ_USER=lms
RABBITMQ_PASSWORD=lms_password
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# ─── MinIO (файловое хранилище) ─────────────────────────────────────────────
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://minio:9000
S3_BUCKET=lms-files

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret-change-me-refresh-secret

# ─── Frontend ───────────────────────────────────────────────────────────────
FRONTEND_PORT=5173

# Локальная разработка: VITE_API_URL=http://localhost:8080
# Прод (через Caddy):   VITE_API_URL=  (оставить пустым — Caddy проксирует /api/*)
VITE_API_URL=http://localhost:8080

# ─── CORS (Gateway) ─────────────────────────────────────────────────────────
# Локальная разработка: http://localhost:5173
# Прод:                 https://YOUR-URL
FRONTEND_URL=http://localhost:5173

# ─── Caddy (только для прода с доменом и TLS) ───────────────────────────────
# Для локальной разработки эти переменные не нужны — Caddy не запускается.
# APP_DOMAIN=url
# ACME_EMAIL=admin@YOUR-URL
# HTTP_PORT=80
# HTTPS_PORT=443
